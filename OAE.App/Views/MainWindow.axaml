<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OAE.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        Width="1200" Height="720"
        x:Class="OAE.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="#0F1115"
        Title="OZX Assets Editor">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Section labels: a calm uppercase tracking-wide caption. -->
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="#7A8290"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Pane chrome: subtle right divider only; backgrounds set per-pane. -->
        <Style Selector="Border.divider">
            <Setter Property="BorderBrush" Value="#1F242C"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <!-- Status pill in the top toolbar. -->
        <Style Selector="Border.statusOk">
            <Setter Property="Background" Value="#163C2A"/>
            <Setter Property="BorderBrush" Value="#1F5A3D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.statusBad">
            <Setter Property="Background" Value="#3C1F22"/>
            <Setter Property="BorderBrush" Value="#5A2A30"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.statusOk TextBlock">
            <Setter Property="Foreground" Value="#9BE3B5"/>
        </Style>
        <Style Selector="Border.statusBad TextBlock">
            <Setter Property="Foreground" Value="#E39B9B"/>
        </Style>

        <!-- Tighten ListBox visuals to fit the dense layout. -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- Top toolbar: project root + status + open button -->
        <Border DockPanel.Dock="Top" Padding="16,12" Background="#141821"
                BorderBrush="#1F242C" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Classes="section" Text="PROJECT ROOT"/>
                    <TextBlock Text="{Binding ProjectRootDisplay}"
                               FontFamily="Menlo,Monaco,Consolas" FontSize="12.5"
                               Foreground="#D8DCE4"/>
                </StackPanel>

                <Border Grid.Column="1" CornerRadius="6" Padding="10,6"
                        Classes.statusOk="{Binding IsProjectValid}"
                        Classes.statusBad="{Binding !IsProjectValid}"
                        VerticalAlignment="Center" Margin="4,0,0,0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding StatusDetail}" FontSize="11" Opacity="0.85"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="3" Content="Images…" Click="OnImagesClick"
                        Padding="14,8" Margin="0,0,6,0" VerticalAlignment="Center"
                        IsEnabled="{Binding IsProjectValid}"/>
                <Button Grid.Column="4" Content="Resources…" Click="OnResourcesClick"
                        Padding="14,8" Margin="0,0,6,0" VerticalAlignment="Center"
                        IsEnabled="{Binding IsProjectValid}"/>
                <Button Grid.Column="5" Content="Sounds…" Click="OnSoundsClick"
                        Padding="14,8" Margin="0,0,6,0" VerticalAlignment="Center"
                        IsEnabled="{Binding IsProjectValid}"/>
                <Button Grid.Column="6" Content="Tilemaps…" Click="OnTilemapsClick"
                        Padding="14,8" Margin="0,0,6,0" VerticalAlignment="Center"
                        IsEnabled="{Binding IsProjectValid}"/>
                <Button Grid.Column="7" Content="Minimap…" Click="OnMinimapClick"
                        Padding="14,8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Grid.Column="8" Content="Open Project…" Click="OnOpenProjectClick"
                        Padding="14,8" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body: type list | entity list | detail -->
        <Grid ColumnDefinitions="220,320,*">

            <!-- LEFT: type list -->
            <Border Grid.Column="0" Classes="divider" Background="#0F1115" Padding="0,12">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Classes="section" Text="ASSET TYPES" Margin="14,0,14,8"/>
                    <ListBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"
                             Padding="6,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:TypeListItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Id}"
                                               FontFamily="Menlo,Monaco,Consolas" FontSize="13"/>
                                    <Border Grid.Column="1" Background="#1F2530" CornerRadius="10"
                                            Padding="7,1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Count}" Foreground="#A3ADBA" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- MIDDLE: entity list -->
            <Border Grid.Column="1" Classes="divider" Background="#13171F" Padding="0,12">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="14,0,10,6">
                        <TextBlock Grid.Column="0" Classes="section" Text="ENTITIES" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ New" Click="OnNewEntityClick" Padding="10,3"
                                FontSize="11"
                                IsEnabled="{Binding SelectedType, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </Grid>
                    <TextBox DockPanel.Dock="Top" Margin="10,0,10,8"
                             PlaceholderText="Filter…" Text="{Binding EntityFilter, Mode=TwoWay}"/>
                    <ListBox ItemsSource="{Binding Entities}" SelectedItem="{Binding SelectedEntity}"
                             Padding="6,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:EntityListItem">
                                <StackPanel>
                                    <TextBlock Text="{Binding Id}"
                                               FontFamily="Menlo,Monaco,Consolas" FontSize="13"/>
                                    <TextBlock Text="{Binding Path}" FontSize="10"
                                               Foreground="#5C6573" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- RIGHT: detail pane -->
            <Border Grid.Column="2" Background="#181C25">
                <DockPanel LastChildFill="True">
                    <!-- Action bar -->
                    <Border DockPanel.Dock="Top" Padding="16,10" Background="#141821"
                            BorderBrush="#1F242C" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Fill="#FFC83D"
                                         IsVisible="{Binding IsDirty}" ToolTip.Tip="Unsaved changes"/>
                                <TextBlock Text="{Binding SaveStatus}" Foreground="#7A8290" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Revert" Click="OnRevertClick" Margin="6,0"
                                    IsEnabled="{Binding IsDirty}"/>
                            <Button Grid.Column="3" Content="Save" Click="OnSaveClick" Padding="16,7"
                                    IsEnabled="{Binding IsDirty}"
                                    Background="#2C6BE6" Foreground="White"/>
                        </Grid>
                    </Border>

                    <!-- Tabs: Form / Images / Raw JSON -->
                    <TabControl Padding="0">
                        <TabItem Header="Form">
                            <ScrollViewer Padding="20,12,20,20">
                                <StackPanel Name="FormHost" Spacing="2"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Images">
                            <ScrollViewer Padding="20,12,20,20">
                                <WrapPanel Name="ImagesHost" ItemSpacing="14" LineSpacing="14"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Raw JSON">
                            <ScrollViewer Padding="20,12,20,20">
                                <TextBox Text="{Binding RawJson, Mode=OneWay}" IsReadOnly="True"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         FontFamily="Menlo,Monaco,Consolas" FontSize="12"
                                         Background="#0F1115" Foreground="#D8DCE4"
                                         BorderBrush="#1F242C" BorderThickness="1" Padding="12"/>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
