<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OAE.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        Width="1200" Height="720"
        x:Class="OAE.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="OZX Assets Editor">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.statusOk">
            <Setter Property="Background" Value="#1E4D2B"/>
        </Style>
        <Style Selector="Border.statusBad">
            <Setter Property="Background" Value="#5C2B2B"/>
        </Style>
        <Style Selector="Border.pane">
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- Top toolbar: project root + status + open button -->
        <Border DockPanel.Dock="Top" Padding="14,10" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Classes="label" Text="PROJECT ROOT"/>
                    <TextBlock Text="{Binding ProjectRootDisplay}" FontFamily="Menlo,Monaco,Consolas" FontSize="13"/>
                </StackPanel>

                <Border Grid.Column="1" CornerRadius="4" Padding="10,6"
                        Classes.statusOk="{Binding IsProjectValid}"
                        Classes.statusBad="{Binding !IsProjectValid}"
                        HorizontalAlignment="Left" Margin="8,0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding StatusDetail}" FontSize="11" Opacity="0.85"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="2" Content="Open Project…" Click="OnOpenProjectClick"
                        Padding="14,6" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body: type list | entity list | detail -->
        <Grid ColumnDefinitions="220,300,*">

            <!-- LEFT: type list -->
            <Border Grid.Column="0" Classes="pane" Background="#181818">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Classes="label" Text="ASSET TYPES" Margin="14,12,14,4"/>
                    <ListBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"
                             Background="Transparent" BorderThickness="0" Padding="6,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:TypeListItem">
                                <Grid ColumnDefinitions="*,Auto" Margin="2,1">
                                    <TextBlock Grid.Column="0" Text="{Binding Id}" FontFamily="Menlo,Monaco,Consolas"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Count}" Opacity="0.6" Margin="8,0,4,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- MIDDLE: entity list -->
            <Border Grid.Column="1" Classes="pane" Background="#1C1C1C">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Classes="label" Text="ENTITIES" Margin="14,12,14,4"/>
                    <TextBox DockPanel.Dock="Top" Margin="10,0,10,8"
                             PlaceholderText="Filter…" Text="{Binding EntityFilter, Mode=TwoWay}"/>
                    <ListBox ItemsSource="{Binding Entities}" SelectedItem="{Binding SelectedEntity}"
                             Background="Transparent" BorderThickness="0" Padding="6,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:EntityListItem">
                                <StackPanel Margin="2,2">
                                    <TextBlock Text="{Binding Id}" FontFamily="Menlo,Monaco,Consolas"/>
                                    <TextBlock Text="{Binding Path}" FontSize="10" Opacity="0.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- RIGHT: detail pane -->
            <Border Grid.Column="2" Background="#222">
                <DockPanel LastChildFill="True">
                    <!-- Action bar -->
                    <Border DockPanel.Dock="Top" Padding="14,10" BorderBrush="#333" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="●" Foreground="#FFCC00" FontSize="14"
                                           IsVisible="{Binding IsDirty}" ToolTip.Tip="Unsaved changes"/>
                                <TextBlock Text="{Binding SaveStatus}" Opacity="0.65" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Revert" Click="OnRevertClick" Margin="6,0"
                                    IsEnabled="{Binding IsDirty}"/>
                            <Button Grid.Column="3" Content="Save" Click="OnSaveClick" Padding="14,6"
                                    IsEnabled="{Binding IsDirty}"/>
                        </Grid>
                    </Border>

                    <!-- Tabs: Form / Raw JSON -->
                    <TabControl Padding="0">
                        <TabItem Header="Form">
                            <ScrollViewer Padding="14">
                                <StackPanel Name="FormHost" Spacing="2"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Raw JSON">
                            <ScrollViewer Padding="14">
                                <TextBox Text="{Binding RawJson, Mode=OneWay}" IsReadOnly="True"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         FontFamily="Menlo,Monaco,Consolas" FontSize="12"
                                         Background="Transparent" BorderThickness="0"/>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
