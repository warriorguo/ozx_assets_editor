<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        Width="1100" Height="700"
        x:Class="OAE.App.Views.MinimapWindow"
        Title="Minimap"
        Background="#181C25"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#7A8290"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.pane">
            <Setter Property="BorderBrush" Value="#1F242C"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
        </Style>
        <Style Selector="TextBlock.detailKey">
            <Setter Property="Foreground" Value="#7A8290"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="TextBlock.detailVal">
            <Setter Property="Foreground" Value="#D8DCE4"/>
            <Setter Property="FontFamily" Value="Menlo,Monaco,Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#141821" Padding="14,10"
                BorderBrush="#1F242C" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Classes="label" Text="FLOOR MINIMAP"/>
                    <TextBlock Name="StatusText" Foreground="#D8DCE4" FontSize="12.5"
                               Text="(not loaded)"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Refresh" Click="OnRefreshClick"
                        Padding="14,6"/>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,320">
            <!-- LEFT: minimap canvas (or error message). -->
            <Border Grid.Column="0" Background="#0F1115" Padding="0">
                <Grid>
                    <ScrollViewer Name="MapScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Canvas Name="MapCanvas" Background="#0F1115"/>
                    </ScrollViewer>
                    <TextBlock Name="ErrorText"
                               IsVisible="False"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#E39B9B" FontSize="13" TextWrapping="Wrap"
                               MaxWidth="520" TextAlignment="Center"/>
                </Grid>
            </Border>

            <!-- RIGHT: room detail panel. -->
            <Border Grid.Column="1" Classes="pane" Background="#181C25" Padding="16,14">
                <ScrollViewer>
                    <StackPanel Name="DetailHost" Spacing="10">
                        <TextBlock Text="(click a room on the map)"
                                   Foreground="#7A8290" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
