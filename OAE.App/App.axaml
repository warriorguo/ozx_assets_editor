<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OAE.App.App"
             xmlns:local="using:OAE.App"
             RequestedThemeVariant="Dark">
             <!-- Force Dark so Fluent's input/control palette matches the panel backgrounds painted in MainWindow. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>